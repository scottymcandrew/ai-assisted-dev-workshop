# ===========================================
# AI Dev Workshop — Environment Configuration
# ===========================================
# Copy to .env and update with your values:
#   cp .env.example .env

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---- SendGrid ----
SENDGRID_API_KEY=SG.REPLACE_ME
SENDGRID_FROM_EMAIL=noreply@acme-corp.dev

# ---- Application ----
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---- Amazon Bedrock (used by setup.sh to configure Claude Code) ----
# AWS_REGION is required by Claude Code for Bedrock; it does not read region from ~/.aws/config alone.
AWS_REGION=us-east-1
# Cross-region inference profile IDs (see https://code.claude.com/docs/en/amazon-bedrock)
ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Optional: ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6-v1
#
# Bedrock API key (optional): if set, setup.sh writes AWS_BEARER_TOKEN_BEDROCK into ~/.claude/settings.json.
# For facilitator bundles, prefer a single-line file .bedrock-lab-bearer (gitignored).
# AWS_BEARER_TOKEN_BEDROCK=
